import React, { useState, useMemo } from 'react';
import {
  Typography,
  Container,
  Card,
  CardContent,
  FormControl,
  InputLabel,
  Select,
  MenuItem,
  Button,
  Box,
  Table,
  TableBody,
  TableCell,
  TableContainer,
  TableHead,
  TableRow,
  Paper,
  Grid,
  Chip,
  LinearProgress,
  Avatar,
  useTheme,
  alpha,
} from '@mui/material';
import {
  PlayArrow as PlayIcon,
  People as PeopleIcon,
  TrendingUp as TrendingUpIcon,
  Assessment as AssessmentIcon,
} from '@mui/icons-material';
import { BarChart, Bar, XAxis, YAxis, CartesianGrid, Tooltip, Legend, ResponsiveContainer } from 'recharts';
import { motion } from 'framer-motion';
import scenarios, { Scenario } from '../data/collaborative-fairness';

const CollaborativeFairness: React.FC = () => {
  const theme = useTheme();
  const [selectedScenario, setSelectedScenario] = useState<string>('balanced');
  const [evaluationResult, setEvaluationResult] = useState<Scenario | null>(null);
  const [isLoading, setIsLoading] = useState(false);

  const handleScenarioChange = (event: any) => {
    setEvaluationResult(null);
    setSelectedScenario(event.target.value as string);
  };

  const handleRunEvaluation = () => {
    setIsLoading(true);
    // Simulate loading time for better UX
    setTimeout(() => {
      setEvaluationResult(scenarios[selectedScenario]);
      setIsLoading(false);
    }, 1500);
  };

  const chartData = useMemo(() => {
    if (!evaluationResult) return [];
    return evaluationResult.clients.map(client => ({
      name: client.id,
      'Traditional Score': client.traditionalScore,
      'Proposed Score': client.proposedScore,
      'True Contribution': client.trueContribution,
    }));
  }, [evaluationResult]);

  const getScenarioStatus = (scenario: string) => {
    const statuses = {
      balanced: { label: 'Balanced', color: 'success' },
      imbalanced: { label: 'Imbalanced', color: 'warning' },
      noisy: { label: 'Noisy Data', color: 'error' },
    };
    return statuses[scenario as keyof typeof statuses] || { label: 'Unknown', color: 'default' };
  };

  return (
    <Container maxWidth="xl" sx={{ py: 4 }}>
      {/* Header Section */}
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        animate={{ opacity: 1, y: 0 }}
        transition={{ duration: 0.6 }}
      >
        <Card sx={{ 
          mb: 4, 
          background: `linear-gradient(135deg, ${theme.palette.primary.main} 0%, ${theme.palette.primary.light} 100%)`,
          color: 'white',
        }}>
          <CardContent sx={{ p: { xs: 3, md: 4 } }}>
            <Box sx={{ display: 'flex', alignItems: 'center', mb: 2 }}>
              <Avatar sx={{ backgroundColor: 'rgba(255,255,255,0.2)', mr: 2, width: 56, height: 56 }}>
                <PeopleIcon sx={{ fontSize: 32 }} />
              </Avatar>
              <Box>
                <Typography variant="h3" component="h1" sx={{ fontWeight: 700, mb: 1 }}>
                  Collaborative Fairness Evaluation
                </Typography>
                <Typography variant="h6" sx={{ opacity: 0.9 }}>
                  Ensuring Fair Contribution-Based Incentives
                </Typography>
              </Box>
            </Box>
            
            <Typography variant="body1" sx={{ opacity: 0.95, maxWidth: '800px', lineHeight: 1.7 }}>
              This module evaluates the fairness of collaboration among clients in Federated Learning based on the principle 
              of "more contribution, more reward". Our proposed method provides precise evaluation of each client's contribution 
              by analyzing their impact on the global model, effectively filtering out noise and leading to more equitable 
              distribution of incentives.
            </Typography>
          </CardContent>
        </Card>
      </motion.div>

      <Grid container spacing={4}>
        {/* Controls Section */}
        <Grid size={12}>
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ delay: 0.2, duration: 0.6 }}
          >
            <Card>
              <CardContent sx={{ p: 3 }}>
                <Box sx={{ display: 'flex', alignItems: 'center', mb: 3 }}>
                  <AssessmentIcon sx={{ mr: 1, color: theme.palette.primary.main }} />
                  <Typography variant="h5" sx={{ fontWeight: 600 }}>
                    Interactive Simulation
                  </Typography>
                </Box>

                <Grid container spacing={3} alignItems="center">
                  <Grid size={{ xs: 12, md: 6 }}>
                    <FormControl fullWidth>
                      <InputLabel id="scenario-select-label">Select Evaluation Scenario</InputLabel>
                      <Select
                        labelId="scenario-select-label"
                        value={selectedScenario}
                        label="Select Evaluation Scenario"
                        onChange={handleScenarioChange}
                      >
                        {Object.entries(scenarios).map(([key, scenario]) => (
                          <MenuItem key={key} value={key}>
                            <Box sx={{ display: 'flex', alignItems: 'center', width: '100%' }}>
                              <Typography sx={{ flexGrow: 1 }}>{scenario.name}</Typography>
                              <Chip 
                                size="small" 
                                label={getScenarioStatus(key).label}
                                color={getScenarioStatus(key).color as any}
                                sx={{ ml: 1 }}
                              />
                            </Box>
                          </MenuItem>
                        ))}
                      </Select>
                    </FormControl>
                  </Grid>

                  <Grid size={{ xs: 12, md: 6 }}>
                    <Button
                      variant="contained"
                      size="large"
                      onClick={handleRunEvaluation}
                      disabled={isLoading}
                      startIcon={!isLoading && <PlayIcon />}
                      sx={{ 
                        minWidth: 200,
                        height: 56,
                        background: `linear-gradient(45deg, ${theme.palette.primary.main} 30%, ${theme.palette.primary.light} 90%)`,
                      }}
                    >
                      {isLoading ? 'Running Evaluation...' : 'Run Fairness Evaluation'}
                    </Button>
                  </Grid>
                </Grid>

                {isLoading && (
                  <Box sx={{ mt: 3 }}>
                    <LinearProgress />
                    <Typography variant="body2" color="text.secondary" sx={{ mt: 1, textAlign: 'center' }}>
                      Analyzing client contributions and computing fairness metrics...
                    </Typography>
                  </Box>
                )}

                {selectedScenario && (
                  <Paper variant="outlined" sx={{ mt: 3, p: 2, backgroundColor: alpha(theme.palette.primary.main, 0.05) }}>
                    <Typography variant="body2" color="text.secondary" sx={{ fontStyle: 'italic' }}>
                      <strong>Scenario Description:</strong> {scenarios[selectedScenario].description}
                    </Typography>
                  </Paper>
                )}
              </CardContent>
            </Card>
          </motion.div>
        </Grid>

        {/* Results Section */}
        {evaluationResult && (
          <Grid size={12}>
            <motion.div
              initial={{ opacity: 0, y: 30 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ duration: 0.6 }}
            >
              <Card>
                <CardContent sx={{ p: 3 }}>
                  <Box sx={{ display: 'flex', alignItems: 'center', mb: 3 }}>
                    <TrendingUpIcon sx={{ mr: 1, color: theme.palette.success.main }} />
                    <Typography variant="h5" sx={{ fontWeight: 600 }}>
                      Evaluation Results: {evaluationResult.name}
                    </Typography>
                    <Chip 
                      label={getScenarioStatus(selectedScenario).label}
                      color={getScenarioStatus(selectedScenario).color as any}
                      sx={{ ml: 2 }}
                    />
                  </Box>

                  <Grid container spacing={4}>
                    {/* Chart Section */}
                    <Grid size={{ xs: 12, lg: 7 }}>
                      <Box sx={{ mb: 2 }}>
                        <Typography variant="h6" sx={{ mb: 1, fontWeight: 600 }}>
                          Contribution Score Comparison
                        </Typography>
                        <Typography variant="body2" color="text.secondary">
                          Comparing traditional size-based scoring vs. our proposed contribution-aware method
                        </Typography>
                      </Box>
                      
                      <Paper variant="outlined" sx={{ p: 2 }}>
                        <Box sx={{ height: 400 }}>
                          <ResponsiveContainer width="100%" height="100%">
                            <BarChart data={chartData} margin={{ top: 20, right: 30, left: 20, bottom: 5 }}>
                              <CartesianGrid strokeDasharray="3 3" />
                              <XAxis dataKey="name" />
                              <YAxis />
                              <Tooltip 
                                formatter={(value, name) => [
                                  `${(value as number).toFixed(3)}`,
                                  name
                                ]}
                              />
                              <Legend />
                              <Bar dataKey="Traditional Score" fill={theme.palette.grey[400]} />
                              <Bar dataKey="Proposed Score" fill={theme.palette.primary.main} />
                              <Bar dataKey="True Contribution" fill={theme.palette.success.main} />
                            </BarChart>
                          </ResponsiveContainer>
                        </Box>
                      </Paper>
                    </Grid>

                    {/* Table Section */}
                    <Grid size={{ xs: 12, lg: 5 }}>
                      <Box sx={{ mb: 2 }}>
                        <Typography variant="h6" sx={{ mb: 1, fontWeight: 600 }}>
                          Detailed Incentive Allocation
                        </Typography>
                        <Typography variant="body2" color="text.secondary">
                          Proposed fair distribution of incentives based on actual contributions
                        </Typography>
                      </Box>

                      <TableContainer component={Paper} variant="outlined">
                        <Table size="small">
                          <TableHead>
                            <TableRow sx={{ backgroundColor: alpha(theme.palette.primary.main, 0.1) }}>
                              <TableCell sx={{ fontWeight: 600 }}>Client</TableCell>
                              <TableCell align="right" sx={{ fontWeight: 600 }}>Data Size</TableCell>
                              <TableCell align="right" sx={{ fontWeight: 600 }}>Score</TableCell>
                              <TableCell align="right" sx={{ fontWeight: 600 }}>Incentive</TableCell>
                            </TableRow>
                          </TableHead>
                          <TableBody>
                            {evaluationResult.clients.map((client) => (
                              <TableRow 
                                key={client.id}
                                sx={{ '&:nth-of-type(odd)': { backgroundColor: alpha(theme.palette.primary.main, 0.02) } }}
                              >
                                <TableCell sx={{ fontWeight: 500 }}>{client.id}</TableCell>
                                <TableCell align="right">{client.dataSize}</TableCell>
                                <TableCell align="right">{client.proposedScore.toFixed(3)}</TableCell>
                                <TableCell align="right">
                                  <Chip 
                                    size="small"
                                    label={`${client.contribution.toFixed(1)}%`}
                                    sx={{ 
                                      backgroundColor: alpha(theme.palette.success.main, 0.1),
                                      color: theme.palette.success.dark,
                                      fontWeight: 600,
                                    }}
                                  />
                                </TableCell>
                              </TableRow>
                            ))}
                          </TableBody>
                        </Table>
                      </TableContainer>
                    </Grid>
                  </Grid>
                </CardContent>
              </Card>
            </motion.div>
          </Grid>
        )}
      </Grid>
    </Container>
  );
};

export default CollaborativeFairness;
